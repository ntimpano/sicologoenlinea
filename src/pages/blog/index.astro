---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/ui/Container.astro';
import Section from '@/components/ui/Section.astro';
import BlogCard from '@/components/BlogCard.astro';
import BlogSidebar from '@/components/BlogSidebar.astro';
import WhatsAppButton from '@/components/WhatsAppButton.astro';
import { MESSAGES } from '@/utils/whatsapp';

// Obtener todos los posts
const allPosts = await getCollection('blog');

// Ordenar por fecha descendente
const sortedPosts = allPosts.sort((a, b) => b.data.fecha.getTime() - a.data.fecha.getTime());
---

<BaseLayout
  title="Blog"
  description="Artículos sobre salud mental, bienestar emocional y desarrollo personal por el equipo de sicologoenlinea."
>
  <!-- Hero Section -->
  <Section padding="lg" class="bg-gradient-to-br from-accent to-primary-50">
    <Container>
      <div class="text-center max-w-3xl mx-auto">
        <h1 class="mb-6">Blog de Salud Mental</h1>
        <p class="text-xl text-gray-800 leading-relaxed">
          Recursos, consejos y reflexiones para tu bienestar emocional
        </p>
      </div>
    </Container>
  </Section>

  <!-- Blog Posts Grid + Sidebar -->
  <Section padding="lg">
    <Container>
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Main Content -->
        <div class="lg:col-span-2">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {sortedPosts.map((post) => (
              <BlogCard
                title={post.data.title}
                descripcionCorta={post.data.descripcionCorta}
                fecha={post.data.fecha}
                destacado={post.data.destacado}
                slug={post.id.replace('.md', '')}
                imagenUrl={post.data.imagenUrl}
              />
            ))}
          </div>

          {sortedPosts.length === 0 && (
            <div class="text-center py-12">
              <p class="text-gray-600 text-lg">
                Próximamente publicaremos contenido interesante para ti.
              </p>
            </div>
          )}
        </div>

        <!-- Sidebar -->
        <div class="lg:col-span-1">
          <BlogSidebar allPosts={allPosts} />
        </div>
      </div>
    </Container>
  </Section>

  <!-- WhatsApp Floating Button -->
  <WhatsAppButton message={MESSAGES.CONSULTA_GENERAL} variant="floating" position="bottom-right" />
</BaseLayout>