---
export interface Props {
  class?: string;
  padding?: 'sm' | 'md' | 'lg';
}

const { class: className = '', padding = 'md' } = Astro.props;

const paddingClasses = {
  sm: 'p-4',
  md: 'p-6',
  lg: 'p-8',
};

const classes = `glass-card rounded-2xl hover:shadow-soft-lg transition-smooth ${paddingClasses[padding]} ${className}`;
---

<div class={classes}>
  <slot />
</div>