---
import { getCollection, render } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/ui/Container.astro';
import Section from '@/components/ui/Section.astro';
import BlogSidebar from '@/components/BlogSidebar.astro';
import WhatsAppButton from '@/components/WhatsAppButton.astro';
import { formatDate } from '@/utils/format';
import { MESSAGES } from '@/utils/whatsapp';

export const getStaticPaths = (async () => {
  const slugFrom = (entry) => entry.id.replace('.md', '');
  const blogPosts = await getCollection('blog');
  return blogPosts.map((post) => ({
    params: { slug: slugFrom(post) },
    props: { post, slug: slugFrom(post) },
  }));
}) satisfies GetStaticPaths;

const { post, slug: currentSlug } = Astro.props;
const { Content } = await render(post);

// Obtener todos los posts para el sidebar
const allPosts = await getCollection('blog');

// Obtener posts relacionados (excluyendo el actual)
const relatedPosts = allPosts
  .filter((p) => p.id.replace('.md', '') !== currentSlug)
  .sort((a, b) => b.data.fecha.getTime() - a.data.fecha.getTime())
  .slice(0, 3);
---

<BaseLayout
  title={post.data.title}
  description={post.data.descripcionCorta}
  image={post.data.imagenUrl}
  type="article"
>
  <!-- Breadcrumbs -->
  <Section padding="sm" class="bg-gray-50 border-b border-gray-100">
    <Container>
      <nav class="flex items-center gap-2 text-sm text-gray-600">
        <a href="/" class="hover:text-primary transition-smooth">Inicio</a>
        <span>/</span>
        <a href="/blog" class="hover:text-primary transition-smooth">Blog</a>
        <span>/</span>
        <span class="text-gray-900">{post.data.title}</span>
      </nav>
    </Container>
  </Section>

  <!-- Article Content -->
  <Section padding="lg">
    <Container>
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Main Content -->
        <article class="lg:col-span-2">
          <!-- Header -->
          <header class="mb-8">
            {post.data.destacado && (
              <div class="mb-4">
                <span class="inline-block px-3 py-1 bg-secondary text-white rounded-lg text-sm font-bold uppercase">
                  Destacado
                </span>
              </div>
            )}
            
            <h1 class="mb-4">{post.data.title}</h1>
            
            <div class="flex flex-wrap items-center gap-4 text-gray-600">
              <div class="flex items-center gap-2">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                </svg>
                <span>{post.data.autor}</span>
              </div>
              
              <div class="flex items-center gap-2">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
                <time datetime={post.data.fecha.toISOString()}>
                  {formatDate(post.data.fecha)}
                </time>
              </div>
            </div>
          </header>

          <!-- Featured Image -->
          {post.data.imagenUrl && (
            <div class="mb-8">
              <img
                src={post.data.imagenUrl}
                alt={post.data.title}
                class="w-full rounded-2xl shadow-soft-md"
                loading="eager"
              />
            </div>
          )}

          <!-- Article Content with Prose Styling -->
          <div class="prose prose-lg max-w-none prose-headings:font-bold prose-headings:text-black prose-h2:text-3xl prose-h3:text-2xl prose-p:text-gray-700 prose-p:leading-relaxed prose-a:text-primary prose-a:no-underline hover:prose-a:underline prose-strong:text-black prose-ul:text-gray-700 prose-ol:text-gray-700">
            <Content />
          </div>

          <!-- Share Buttons -->
          <div class="mt-12 pt-8 border-t border-gray-200">
            <h3 class="text-lg font-bold mb-4">Compartir este artículo</h3>
            <div class="flex gap-4">
              <a
                href={`https://wa.me/?text=${encodeURIComponent(post.data.title + ' ' + Astro.url.href)}`}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 px-4 py-2 bg-[#25D366] text-white rounded-lg hover:bg-[#20BA5A] transition-smooth"
              >
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
                </svg>
                WhatsApp
              </a>
              
              <a
                href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(Astro.url.href)}`}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 px-4 py-2 bg-[#1877F2] text-white rounded-lg hover:bg-[#145dbf] transition-smooth"
              >
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                </svg>
                Facebook
              </a>
            </div>
          </div>

          <!-- CTA -->
          <div class="mt-12 p-8 bg-gradient-to-br from-primary-50 to-secondary-50 rounded-2xl">
            <h3 class="text-2xl font-bold mb-3">¿Necesitas apoyo profesional?</h3>
            <p class="text-gray-700 mb-6">
              Si te identificas con este artículo y sientes que necesitas ayuda, estamos aquí para ti. Agenda una sesión con nuestro equipo de psicólogos.
            </p>
            <WhatsAppButton message={MESSAGES.CONSULTA_ARTICULO(post.data.title)}>
              Contactar ahora
            </WhatsAppButton>
          </div>

          <!-- Related Posts -->
          {relatedPosts.length > 0 && (
            <div class="mt-12">
              <h3 class="text-2xl font-bold mb-6">Artículos relacionados</h3>
              <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                {relatedPosts.map((relatedPost) => (
                  <a href={`/blog/${relatedPost.id.replace('.md', '')}`} class="group">
                    <div class="bg-white rounded-xl shadow-soft p-4 hover:shadow-soft-md transition-smooth">
                      <h4 class="font-bold text-sm mb-2 group-hover:text-primary transition-smooth line-clamp-2">
                        {relatedPost.data.title}
                      </h4>
                      <p class="text-xs text-gray-600">
                        {formatDate(relatedPost.data.fecha)}
                      </p>
                    </div>
                  </a>
                ))}
              </div>
            </div>
          )}
        </article>

        <!-- Sidebar -->
        <aside class="lg:col-span-1">
          <BlogSidebar allPosts={allPosts} />
        </aside>
      </div>
    </Container>
  </Section>

  <!-- WhatsApp Floating Button -->
  <WhatsAppButton message={MESSAGES.CONSULTA_GENERAL} variant="floating" position="bottom-right" />
</BaseLayout>