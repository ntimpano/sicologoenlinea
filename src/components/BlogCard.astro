---
import Card from './ui/Card.astro';
import { formatDate } from '@/utils/format';

export interface Props {
  title: string;
  descripcionCorta: string;
  fecha: Date;
  destacado?: boolean;
  slug: string;
  imagenUrl?: string;
}

const {
  title,
  descripcionCorta,
  fecha,
  destacado = false,
  slug,
  imagenUrl,
} = Astro.props;
---

<Card class="flex flex-col h-full hover:scale-[1.02] transition-all">
  {destacado && (
    <div class="mb-3">
      <span class="inline-block px-3 py-1 bg-secondary text-white rounded-lg text-xs font-bold uppercase">
        Destacado
      </span>
    </div>
  )}

  <div class="mb-4">
    {imagenUrl ? (
      <img
        src={imagenUrl}
        alt={title}
        class="w-full h-48 object-cover rounded-xl"
        loading="lazy"
      />
    ) : (
      <div class="w-full h-48 bg-gradient-to-br from-primary-100 to-secondary-100 rounded-xl flex items-center justify-center">
        <svg class="w-16 h-16 text-primary-300" fill="currentColor" viewBox="0 0 20 20">
          <path d="M9 4.804A7.968 7.968 0 005.5 4c-1.255 0-2.443.29-3.5.804v10A7.969 7.969 0 015.5 14c1.669 0 3.218.51 4.5 1.385A7.962 7.962 0 0114.5 14c1.255 0 2.443.29 3.5.804v-10A7.968 7.968 0 0014.5 4c-1.255 0-2.443.29-3.5.804V12a1 1 0 11-2 0V4.804z" />
        </svg>
      </div>
    )}
  </div>

  <div class="flex items-center gap-2 mb-3 text-sm text-gray-600">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
    </svg>
    <time datetime={fecha.toISOString()}>
      {formatDate(fecha)}
    </time>
  </div>

  <h3 class="text-xl font-bold mb-3 flex-grow">
    <a href={`/blog/${slug}`} class="hover:text-primary transition-smooth">
      {title}
    </a>
  </h3>

  <p class="text-gray-700 mb-4 text-sm">
    {descripcionCorta}
  </p>

  <a
    href={`/blog/${slug}`}
    class="inline-flex items-center gap-2 text-primary font-medium hover:gap-3 transition-all"
  >
    Leer más
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
    </svg>
  </a>
</Card>